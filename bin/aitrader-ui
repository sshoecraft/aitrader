#!/usr/bin/python3
"""trader-ui launcher with ports from settings.toml — portable across users.

The dashboard UI (trader_ui) needs an explicit serve port (--port) and the
backend API port (--api-port). Hardcoding those in the systemd unit isn't
portable: host-global ports, so every user would collide. This thin launcher
reads them from ~/.config/aitrader/settings.toml so the SAME aitrader-ui.service
works for any user:

  * api_port — settings.toml key (default 2499). aitrader-api reads the same key,
               so backend and UI always agree.
  * ui_port  — settings.toml key (default 2500). An EXPLICIT default, NOT
               api_port+1 — the hidden +1 coupling was fragile.

If portd (the Caddy dynamic-port plugin) is running, the UI serves on a port it
allocates and the SPA reaches the API via Caddy's /<portd_name>-api/ path (not a
port) — see aitrader/portd.py. portd absent → the settings.toml defaults above.

trader_ui injects --api-port into the SPA at runtime via its /config.js route, so
no rebuild is needed to point the UI at a different API port. Extra args are
passed straight through to trader_ui.
"""
import os
import sys

from aitrader import portd
from aitrader.config import settings

s = settings()
# If portd is running: serve on the UI port it allocates (Caddy routes
# /<portd_name>/ → here) and tell the SPA to reach the API via Caddy's same-origin
# path /<portd_name>-api/ — NOT host:port, since the allocated API port is
# localhost-only and the public host is shared. allocate() is idempotent +
# name-keyed, so this registers the API route even if the UI starts first. If
# portd isn't running both probes fail fast (~1s cap) → serve ui_port + inject
# the direct api_port.
# portd names come from settings.toml (portd_name, default "<unix-user>-aitrader")
# so each user's stack registers a DISTINCT route — a shared name makes the second
# allocate() clobber the first. The UI is "<portd_name>", the API "<portd_name>-api".
ui_name = s.portd_name
api_name = f"{s.portd_name}-api"
ui_port = portd.allocate(ui_name) or s.ui_port
if portd.allocate(api_name):
    api_args = ["--api-base", f"/{api_name}"]
else:
    api_args = ["--api-port", str(s.api_port)]

trader_ui = os.path.expanduser("~/.local/bin/trader_ui")
os.execv(trader_ui, [trader_ui, "--port", str(ui_port), *api_args, *sys.argv[1:]])
